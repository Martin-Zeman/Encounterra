{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Encounterra Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/c++/build/bin/encounterra",
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
            ]
        },
        {
            "name": "Encounterra Test Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/c++/build/test/test_encounterra",
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
            ]
        }
    ]
}